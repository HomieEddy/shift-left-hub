{
  "name": "shiftleft-hub",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "tailwind:css": "tailwindcss -i src/tailwind.src.css -o src/styles.css",
    "prestart": "pnpm tailwind:css",
    "start": "ng serve",
    "start:docker": "sh -c \"tailwindcss -i src/tailwind.src.css -o src/styles.css --watch & ng serve --host 0.0.0.0 --port 4200 --poll 1000 --proxy-config proxy.docker.conf.json\"",
    "prebuild": "pnpm tailwind:css",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,json,css}\"",
    "test": "ng test",
    "e2e": "npx playwright test --config ../playwright.config.ts",
    "e2e:ui": "npx playwright test --config ../playwright.config.ts --ui"
  },
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/localize": "^21.2.15",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@lucide/angular": "^1.17.0",
    "ngx-markdown": "^21.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.2.0",
    "@angular-eslint/eslint-plugin": "^21.2.0",
    "@angular-eslint/eslint-plugin-template": "^21.2.0",
    "@angular-eslint/template-parser": "^21.2.0",
    "@angular/build": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.7",
    "angular-eslint": "^21.4.0",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.30.0",
    "vitest": "^4.0.8"
  }
}