FROM node:22-alpine

WORKDIR /app

# Install all deps as root (no need to switch to appuser in dev)
RUN corepack enable

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

EXPOSE 4200

# Run the dev server as root. This is dev-only — production uses a
# multi-stage Dockerfile with a non-root user. The WSL2/Docker Desktop
# environment on this machine drops CAP_SETUID from containers, which
# breaks gosu/setpriv/su-based privilege drop. Running as root is the
# pragmatic choice for local dev.
CMD ["pnpm", "run", "start:docker"]
