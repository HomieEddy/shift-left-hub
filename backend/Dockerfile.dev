FROM eclipse-temurin:21-jdk

WORKDIR /app

RUN useradd --create-home --home-dir /home/app --shell /bin/bash app \
	&& mkdir -p /home/app/.m2 \
	&& chown -R app:app /app /home/app

ENV HOME=/home/app

# Prime Maven dependency cache for faster container startup.
COPY .mvn .mvn
COPY mvnw mvnw.cmd pom.xml ./
RUN chmod +x mvnw && chown app:app mvnw mvnw.cmd pom.xml

USER app

RUN ./mvnw -q -DskipTests dependency:go-offline

EXPOSE 8080

CMD ["sh", "-c", "chmod +x mvnw && ./mvnw -DskipTests spring-boot:run"]
