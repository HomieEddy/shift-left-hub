<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">
<suppressions>
    <suppress files="[\\/]generated[\\/]" checks=".*"/>
    <suppress files=".*[\\/]dto[\\/]" checks="JavadocMethod|MissingJavadocMethod|MissingJavadocType"/>
    <suppress files=".*[\\/]domain[\\/].*(Exception|Event)" checks="MissingJavadocType|MissingJavadocMethod"/>
</suppressions>
