<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- EI_EXPOSE_REP/EI_EXPOSE_REP2: DTO records intentionally expose internal arrays -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Or>
            <Package name="~.*\.dto"/>
            <Package name="~.*\.api\.dto"/>
        </Or>
    </Match>
    <!-- SE_BAD_FIELD: JPA entities are not serialized through Java serialization -->
    <Match>
        <Bug pattern="SE_BAD_FIELD,SE_BAD_FIELD_STORE,SE_NO_SERIALVERSIONID"/>
        <Package name="~.*\.domain"/>
    </Match>
    <!-- EI_EXPOSE_REP2: Constructor injection of Spring beans (proxies, not externally mutable) -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Or>
            <Package name="~.*\.config"/>
            <Package name="~.*\.service"/>
        </Or>
    </Match>
    <!-- VA_FORMAT_STRING_USES_NEWLINE: Text blocks with .formatted() — Java text blocks normalize to \n -->
    <Match>
        <Bug pattern="VA_FORMAT_STRING_USES_NEWLINE"/>
    </Match>
    <!-- Pre-existing PATH_TRAVERSAL_IN in DocumentService — file upload path builder uses configured base dir -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN"/>
        <Package name="~.*\.document\.service"/>
    </Match>
    <!-- Pre-existing CRLF_INJECTION_LOGS — logging with user-controlled data, acceptable risk -->
    <Match>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
    </Match>
    <!-- SPRING_CSRF_PROTECTION_DISABLED: Stateless JWT API — CSRF is mitigated by SameSite=Strict cookies (SEC-04) -->
    <Match>
        <Bug pattern="SPRING_CSRF_PROTECTION_DISABLED"/>
    </Match>
    <!-- CT_CONSTRUCTOR_THROW in JwtService: validateSecret is a static
         method that throws on weak/dev-literal secrets before any
         field is assigned, so no partially-constructed object is
         exposed. The fail-fast is the correct behavior (S-6). -->
    <Match>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
        <Class name="com.shiftleft.hub.config.JwtService"/>
    </Match>
</FindBugsFilter>
