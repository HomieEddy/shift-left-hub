# Database
POSTGRES_DB=shiftleft
POSTGRES_USER=shiftleft
POSTGRES_PASSWORD=change-me-to-a-secure-password

# JWT
APP_JWT_SECRET=change-me-to-a-256-bit-random-secret

# Auth cookies
# Local HTTP development: false/Lax. HTTPS production behind same-origin Vercel rewrites: true/Lax.
APP_AUTH_COOKIE_SECURE=false
APP_AUTH_COOKIE_SAME_SITE=Lax

# Admin seed
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=change-me-to-a-strong-password

# AI Encryption
APP_AI_ENCRYPTION_KEY=change-me-to-a-random-encryption-key
APP_AI_ENCRYPTION_SALT=change-me-to-a-random-salt

# AI Provider
SPRING_AI_OPENAI_API_KEY=sk-your-key-here

# CORS (frontend URL for production)
APP_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
