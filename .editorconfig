root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml,json,md}]
indent_size = 2

[*.{ts,html}]
indent_size = 2
quote_type = single

[*.md]
trim_trailing_whitespace = false

[*.{java,kt}]
indent_size = 4

[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

[*.{sh,bash}]
end_of_line = lf
